    )

# ─────────────────────────────────────────
#  ОБРАБОТЧИКИ
# ─────────────────────────────────────────
@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(welcome_banner(), reply_markup=get_main_kb(), parse_mode="HTML")

@dp.message(Command("stats"))
async def cmd_stats(message: types.Message):
    await message.answer(fmt_stats(), reply_markup=get_main_kb(), parse_mode="HTML")

# ── Выбор длины ──────────────────────────
@dp.callback_query(F.data.in_({"len_5", "len_6", "len_7"}))
async def cb_set_length(call: types.CallbackQuery):
    global selected_length
    if is_running:
        await call.answer("⚠️ Сначала останови поиск!", show_alert=True)
        return
    selected_length = int(call.data.split("_")[1])
    await call.answer(f"✅ Длина: {selected_length} букв")
    # обновляем клавиатуру на месте (галочка переедет)
    await call.message.edit_reply_markup(reply_markup=get_main_kb())

# ── Запуск поиска ──────────────────────────
@dp.callback_query(F.data == "start")
async def cb_start(call: types.CallbackQuery):
    global is_running
    if is_running:
        await call.answer("⚠️ Поиск уже запущен!", show_alert=True)
        return

    is_running = True
    stats["session_start"] = datetime.now()
    stats["checked"] = 0
    stats["found"] = 0
    await call.answer()

    await call.message.answer(
        f"🚀 <b>Поиск запущен!</b>\n"
        f"━━━━━━━━━━━━━━━━━━━\n"
        f"📏 Длина ника: <b>{selected_length} букв</b>\n"
        f"⏱ Проверяю каждые 5 секунд.\n"
        f"Свободные ники появятся здесь 👇",
        reply_markup=get_running_kb(),
        parse_mode="HTML"
    )

    while is_running:
        nick = generate_nice_nick(selected_length)
        result, nick = await check_nick(nick)
        if result is None:
            # невалидный ник — пропускаем без счётчика
            continue
        stats["checked"] += 1
        if result:
            stats["found"] += 1
            await call.message.answer(fmt_free(nick), parse_mode="HTML", disable_web_page_preview=True)
        await asyncio.sleep(5)

# ── Остановка ─────────────────────────────
@dp.callback_query(F.data == "stop")
async def cb_stop(call: types.CallbackQuery):
    global is_running
    if not is_running:
        await call.answer("Поиск и так не запущен.", show_alert=True)
        return
    is_running = False
    await call.answer()
    await call.message.answer(
        f"⏹ <b>Поиск остановлен.</b>\n\n{fmt_stats()}",
        reply_markup=get_main_kb(),
        parse_mode="HTML"
    )

# ── Найти один свободный ──────────────────
@dp.callback_query(F.data == "check_one")
async def cb_check_one(call: types.CallbackQuery):
    await call.answer("⏳ Ищу...")
    status_msg = await call.message.answer(
        f"🔄 <b>Ищу свободный ник ({selected_length} букв)...</b>\n"
        f"<i>Это может занять несколько секунд.</i>",
        parse_mode="HTML"
    )
    attempts = 0
    while True:
        nick = generate_nice_nick(selected_length)
        result, nick = await check_nick(nick)
        if result is None:
            continue  # невалидный — пропускаем
        stats["checked"] += 1
        attempts += 1
        if result:
            stats["found"] += 1
            await status_msg.edit_text(
                f"✅ <b>Найдено за {attempts} попыток!</b>\n\n{fmt_free(nick)}",
                parse_mode="HTML",
                disable_web_page_preview=True
            )
            break
        if attempts % 5 == 0:
            await status_msg.edit_text(
                f"🔄 <b>Ищу свободный ник ({selected_length} букв)...</b>\n"
                f"Проверено: <b>{attempts}</b> вариантов, продолжаю...",
                parse_mode="HTML"
            )
        await asyncio.sleep(1)

# ── Статистика ────────────────────────────
@dp.callback_query(F.data == "stats")
async def cb_stats(call: types.CallbackQuery):
    await call.answer()
    await call.message.answer(fmt_stats(), reply_markup=get_main_kb(), parse_mode="HTML")

# ─────────────────────────────────────────
#  ЗАПУСК
# ─────────────────────────────────────────
async def main():
    await client.start()
    print("✅ Telethon клиент запущен")
    print("🤖 Бот запущен, ожидаю команды...")
    await dp.start_polling(bot)

if __name__ == '__main__':
    asyncio.run(main())
