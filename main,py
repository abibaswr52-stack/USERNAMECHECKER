# ─────────────────────────────────────────
#  ГЕНЕРАТОР ПРОИЗНОСИМЫХ НИКОВ
# ─────────────────────────────────────────
VOWELS     = list("aeiou")
CONSONANTS = list("bcdfghjklmnprstvwxyz")
SOFT_PAIRS = [
    "ar","er","or","an","en","on","al","el","ol",
    "ra","re","ro","na","ne","no","la","le","lo",
    "ma","me","mo","sa","se","so","ta","te","to",
    "va","ve","vo","ka","ke","ko","da","de","do",
    "ba","be","bo","fa","fe","fo","ga","ge","go",
]

def syllable():
    c = random.choice(CONSONANTS)
    v = random.choice(VOWELS)
    if random.random() < 0.5:
        return c + v
    return c + v + random.choice(CONSONANTS)

def generate_nice_nick(length: int = 5) -> str:
    for _ in range(100):
        nick = ""
        while len(nick) < length:
            if random.random() < 0.4 and len(nick) + 2 <= length:
                nick += random.choice(SOFT_PAIRS)
            else:
                syl = syllable()
                if len(nick) + len(syl) <= length:
                    nick += syl
                else:
                    remaining = length - len(nick)
                    if remaining == 1:
                        nick += random.choice(VOWELS)
                    break
        if len(nick) == length:
            return nick
    # fallback: простая генерация если вдруг зациклилось
    return "".join(
        random.choice(CONSONANTS if i % 2 == 0 else VOWELS)
        for i in range(length)
    )

# ─────────────────────────────────────────
#  ПРОВЕРКА НИКА
# ─────────────────────────────────────────
async def check_nick(nick: str):
    try:
        await client.get_entity(nick)
        return False, nick                    # занят
    except (ValueError, UsernameNotOccupiedError):
        return True, nick                     # свободен
    except UsernameInvalidError:
        return None, nick                     # невалидный — пропустить
    except FloodWaitError as e:
        await asyncio.sleep(e.seconds + 2)
        return False, nick
    except Exception:
        return None, nick                     # любая другая ошибка — пропустить

# ─────────────────────────────────────────
#  КЛАВИАТУРЫ
# ─────────────────────────────────────────
def get_main_kb():
    marks = {5: "", 6: "", 7: ""}
    marks[selected_length] = " ✅"
    return InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="▶️ Запустить", callback_data="start"),
            InlineKeyboardButton(text="⏹ Остановить", callback_data="stop"),
        ],
        [
            InlineKeyboardButton(text="🔍 Найти один свободный", callback_data="check_one"),
        ],
        [
            InlineKeyboardButton(text=f"5 букв{marks[5]}", callback_data="len_5"),
            InlineKeyboardButton(text=f"6 букв{marks[6]}", callback_data="len_6"),
            InlineKeyboardButton(text=f"7 букв{marks[7]}", callback_data="len_7"),
        ],
        [
            InlineKeyboardButton(text="📊 Статистика", callback_data="stats"),
        ],
    ])

def get_running_kb():
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="⏹ Остановить поиск", callback_data="stop")],
        [InlineKeyboardButton(text="📊 Статистика", callback_data="stats")],
    ])

# ─────────────────────────────────────────
#  ФОРМАТИРОВАНИЕ
# ─────────────────────────────────────────
def fmt_free(nick: str) -> str:
    return (
        f"🟢 <b>Свободный ник найден!</b>\n"
        f"━━━━━━━━━━━━━━━━━━━\n"
        f"👤  <code>@{nick}</code>\n"
        f"📏  Длина: <b>{len(nick)} символа</b>\n"
        f"🔗  <a href='https://t.me/{nick}'>t.me/{nick}</a>\n"
        f"🌐  <code>{nick}.t.me</code>\n"
        f"━━━━━━━━━━━━━━━━━━━\n"
        f"⏰  {datetime.now().strftime('%H:%M:%S')}"
    )

def fmt_stats() -> str:
    elapsed = "—"
    if stats["session_start"]:
        secs = int((datetime.now() - stats["session_start"]).total_seconds())
        elapsed = f"{secs // 60}м {secs % 60}с"
    return (
        f"📊 <b>Статистика сессии</b>\n"
        f"━━━━━━━━━━━━━━━━━━━\n"
        f"📏  Длина ника:  <b>{selected_length} букв</b>\n"
        f"🔍  Проверено:  <b>{stats['checked']}</b>\n"
        f"✅  Найдено:    <b>{stats['found']}</b>\n"
        f"⏱  Время:      <b>{elapsed}</b>\n"
        f"⚡  Статус:     {'<b>🟢 Работает</b>' if is_running else '<b>🔴 Остановлен</b>'}\n"
        f"━━━━━━━━━━━━━━━━━━━"
    )

